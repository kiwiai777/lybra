{
  "name": "lybra",
  "version": "0.2.0",
  "license": "Apache-2.0",
  "description": "An accountable single-agent autonomy loop + an accountability gate any MCP agent can reach via Form B. Gate, not engine; files are truth; drafter != confirmer != executor.",
  "keywords": [
    "ai-agent",
    "accountability",
    "governance",
    "audit",
    "mcp",
    "harness",
    "tui",
    "file-authoritative",
    "owner-gated"
  ],
  "bin": {
    "lybra": "bin/lybra"
  },
  "scripts": {
    "test:visual": "playwright test --config tests/playwright/playwright.config.cjs",
    "test:visual:headed": "playwright test --config tests/playwright/playwright.config.cjs --headed",
    "test:visual:install": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": ">=1.40.0 <2.0.0"
  },
  "files": [
    "0_control_plane/",
    "3_context_bundles/",
    "bin/",
    "config/",
    "docs/",
    "examples/",
    "templates/",
    "tools/",
    "web/",
    "README.md",
    "package.json",
    "!tools/**/tests/**",
    "!web/**/tests/**",
    "!**/__pycache__/**",
    "!**/*.pyc",
    "!**/.DS_Store",
    "!**/._*",
    "!**/task_cards/**",
    "!.codex/**"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kiwiai777/lybra.git"
  },
  "homepage": "https://github.com/kiwiai777/lybra#readme",
  "bugs": {
    "url": "https://github.com/kiwiai777/lybra/issues"
  }
}
