# Example owner-private Lybra Board environment.
# Copy to a host-local private path such as /etc/lybra/lybra-board.env.

AIPOS_REPO_ROOT=/home/owner/lybra
AIPOS_WORKSPACE_ROOT=/home/owner/ai-project-os
LYBRA_BOARD_HOST=127.0.0.1
LYBRA_BOARD_PORT=8765

# AIPOS-84 safety defaults.
LYBRA_PUBLIC_SIGNUP_ENABLED=false
LYBRA_MULTI_TENANT_ENABLED=false
LYBRA_AUTONOMOUS_PLANNER_RUNTIME_ENABLED=false
LYBRA_AUTONOMOUS_GIT_PUSH_ENABLED=false
LYBRA_REQUIRE_OWNER_DECISION_GATE=true
LYBRA_REQUIRE_INDEPENDENT_AUDIT=true
